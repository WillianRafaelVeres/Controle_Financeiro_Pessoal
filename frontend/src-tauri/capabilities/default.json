{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissoes padrao da janela principal",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/central-financeira-backend",
          "sidecar": true
        }
      ]
    }
  ]
}
